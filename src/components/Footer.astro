---
const base = import.meta.env.BASE_URL;
---

<footer id="footer" class="w-full px-8 py-12 border-t border-white/10">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">

    <!-- Logo -->
    <a href={base} class="flex items-center gap-2">
      <img src={base + "Logo.png"} alt="Trening" class="h-8 w-auto object-contain" />
      <span class="text-pink-500 font-black text-base tracking-wider">Trening</span>
    </a>

    <!-- Links -->
    <nav class="flex flex-wrap justify-center gap-6">
      <a href="#" class="text-white/40 text-xs hover:text-white transition-colors">Nosotros</a>
      <a href="#" class="text-white/40 text-xs hover:text-white transition-colors">Lineamientos</a>
      <a href="#" class="text-white/40 text-xs hover:text-white transition-colors">Seguridad</a>
      <a href="#" class="text-white/40 text-xs hover:text-white transition-colors">Privacidad</a>
      <a href="#" class="text-white/40 text-xs hover:text-white transition-colors">Términos</a>
    </nav>

    <!-- Redes sociales -->
    <div class="flex items-center gap-4">

      <!-- Instagram -->
      <a href="#" class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:border-pink-500 hover:bg-pink-500/10 transition-all duration-200 group">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ffffff60" stroke-width="2" class="group-hover:stroke-pink-500 transition-colors">
          <rect x="2" y="2" width="20" height="20" rx="5"/>
          <circle cx="12" cy="12" r="4"/>
          <circle cx="17.5" cy="6.5" r="0.5" fill="#ffffff60"/>
        </svg>
      </a>

      <!-- TikTok -->
      <a href="#" class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:border-pink-500 hover:bg-pink-500/10 transition-all duration-200 group">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="#ffffff60" class="group-hover:fill-pink-500 transition-colors">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
        </svg>
      </a>

      <!-- X (Twitter) -->
      <a href="#" class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:border-pink-500 hover:bg-pink-500/10 transition-all duration-200 group">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="#ffffff60" class="group-hover:fill-pink-500 transition-colors">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>

    </div>

    <!-- Copyright -->
    <p class="text-white/30 text-xs">© 2026 Trening. CDMX Urban Sports.</p>

  </div>
</footer>