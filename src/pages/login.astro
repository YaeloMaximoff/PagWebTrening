---
import Layout from '../Layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Login — Trening">
  <Navbar />

  <main class="min-h-screen w-full flex items-center justify-center px-4 pt-24 pb-16">
    
    <div class="w-[380px] shrink-0 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-xl shadow-[0_8px_48px_0_rgba(255,45,120,0.15)] p-8 flex flex-col items-center gap-6">

      <!-- Logo -->
      <div class="flex flex-col items-center gap-3">
        <div class="w-16 h-16 rounded-full bg-[#1a0a0f] border border-pink-500/40 flex items-center justify-center">
          <img src={base + "Logo.png"} alt="Trening" class="h-10 w-10 object-contain" />
        </div>
        <span class="text-pink-500 font-black text-2xl tracking-widest">TRENING</span>
      </div>

      <!-- Tabs -->
      <div class="w-full flex border-b border-white/10">
        <button id="tab-login"
        class="flex-1 pb-3 text-xs font-bold tracking-widest text-pink-500 border-b-2 border-pink-500 hover:text-pink-400 transition-all cursor-pointer">
    INICIAR SESIÓN
        </button>
        <button id="tab-register"
    class="flex-1 pb-3 text-xs font-bold tracking-widest text-white/40 border-b-2 border-transparent  hover:text-pink-400 transition-all cursor-pointer">
    CREAR CUENTA
        </button>
        </div>

      <!-- Form Login -->
      <div id="form-login" class="w-full flex flex-col gap-4">
        <div class="flex items-center gap-3 border-b border-white/20 pb-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF2D78" stroke-width="2">
            <circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/>
          </svg>
          <input type="email" placeholder="Correo Electrónico"
            class="w-full bg-transparent text-white text-sm placeholder-white/30 outline-none" />
        </div>
        <div class="flex items-center gap-3 border-b border-white/20 pb-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF2D78" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <input type="password" placeholder="Contraseña"
            class="w-full bg-transparent text-white text-sm placeholder-white/30 outline-none" />
        </div>
        <div class="text-right">
          <a href="#" class="text-white/40 text-xs hover:text-pink-400 transition-colors">¿Olvidaste tu contraseña?</a>
        </div>
        <button id="btn-login"
        class="w-full py-4 rounded-full bg-pink-500 text-black font-black text-sm tracking-widest hover:text-pink-400 transition-all cursor-pointer">
        ENTRAR A MI CUENTA
        </button>
      </div>

      <!-- Form Register -->
      <div id="form-register" class="w-full flex-col gap-4 hidden">
        <div class="flex items-center gap-3 border-b border-white/20 pb-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF2D78" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
          <input type="text" placeholder="Nombre de usuario"
            class="w-full bg-transparent text-white text-sm placeholder-white/30 outline-none" />
        </div>
        <div class="flex items-center gap-3 border-b border-white/20 pb-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF2D78" stroke-width="2">
            <circle cx="12" cy="12" r="4"/><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-3.92 7.94"/>
          </svg>
          <input type="email" placeholder="Correo Electrónico"
            class="w-full bg-transparent text-white text-sm placeholder-white/30 outline-none" />
        </div>
        <div class="flex items-center gap-3 border-b border-white/20 pb-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF2D78" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          <input type="password" placeholder="Contraseña"
            class="w-full bg-transparent text-white text-sm placeholder-white/30 outline-none" />
        </div>
        <button id="btn-register"
        class="w-full py-4 rounded-full bg-pink-500 text-black font-black text-sm tracking-widest hover:text-pink-400 transition-all cursor-pointer">
        CREAR CUENTA
        </button>
     </div>

      <!-- Footer del card -->
      <p class="text-white/30 text-xs text-center leading-relaxed">
        Al continuar, aceptas nuestros<br/>
        <a href="#" class="text-pink-500 hover:underline">Términos de Servicio</a> y 
        <a href="#" class="text-pink-500 hover:underline">Aviso de Privacidad</a>.
      </p>

    </div>
  </main>

  <Footer />
</Layout>

<script>
  const tabLogin = document.getElementById('tab-login');
  const tabRegister = document.getElementById('tab-register');
  const formLogin = document.getElementById('form-login');
  const formRegister = document.getElementById('form-register');

  tabLogin?.addEventListener('click', () => {
    formLogin?.classList.remove('hidden');
    formLogin?.classList.add('flex');
    formRegister?.classList.add('hidden');
    formRegister?.classList.remove('flex');
    tabLogin.classList.add('text-pink-500', 'border-pink-500');
    tabLogin.classList.remove('text-white/40', 'border-transparent');
    tabRegister?.classList.remove('text-pink-500', 'border-pink-500');
    tabRegister?.classList.add('text-white/40', 'border-transparent');
  });

  tabRegister?.addEventListener('click', () => {
    formRegister?.classList.remove('hidden');
    formRegister?.classList.add('flex');
    formLogin?.classList.add('hidden');
    formLogin?.classList.remove('flex');
    tabRegister.classList.add('text-pink-500', 'border-pink-500');
    tabRegister.classList.remove('text-white/40', 'border-transparent');
    tabLogin?.classList.remove('text-pink-500', 'border-pink-500');
    tabLogin?.classList.add('text-white/40', 'border-transparent');
  });

  document.getElementById('btn-login')?.addEventListener('click', () => {
    alert('🚧 Próximamente: conexión al backend');
  });

  document.getElementById('btn-register')?.addEventListener('click', () => {
    alert('🚧 Próximamente: conexión al backend');
  });
</script>